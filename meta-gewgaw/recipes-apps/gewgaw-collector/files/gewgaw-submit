#!/usr/bin/env python3
"""gewgaw-submit — opportunistic uploader (phases 4+5).

Modes (see scan_and_submit_daemons_design.md §8):
  gewgaw-submit          steady-state upload run (hourly timer)
  gewgaw-submit boot     boot phase / first-connect beacon (§8.1)

Steady-state run:
  1. Count closed unsynced sessions + unsynced events; nothing queued => exit.
  2. Candidate selection: APs the collector can see *now* (its open `wifi_ap`
     sessions, last sighting within SESSION_GAP) that are either a configured
     known network (PSK) or, with ALLOW_OPEN, open.
  3. ACQUIRE the radio lease from the collector's arbiter (§6) so the collector
     stops scanning Wi-Fi while we retune the single radio.
  4. For each candidate (capped at MAX_ATTEMPTS): write a transient single-network
     wpa_supplicant conf, (re)start wpa_supplicant@<iface>, wait for association
     + an IPv4 lease, then a 204 connectivity check. First good link wins.
  5. On internet: flush unsynced `events` to gewgaw/<thing>/status, then closed
     unsynced sessions to gewgaw/<thing>/sightings, batched via `aws-iot-mqtt
     pub`; mark rows synced only after each pub exits 0.
  6. Teardown (stop supplicant, flush wlan0, delete transient conf) + RELEASE.

Boot run (§8.1): record a `boot` event *first* (delivery decoupled, so a boot
with no uplink is still reported later with its real time), wait up to
WAIT_FOR_SCAN for the collector's first scan, then connect with a larger lease
and a BOOT_CONNECT_BUDGET retry budget, confirm NTPSynchronized, re-stamp the
boot event with the corrected clock + link info, and flush events + sightings.

Candidate reputation (§9): a per-BSSID net_health blacklist cools down APs that
fail to associate / DHCP / pass the 204 check, with exponential backoff (gentler
for configured PSK networks, harsher for captive portals), so the brief upload
window isn't wasted re-trying dead hotspots. Each attempt is pinned to one BSSID
so an open SSID present at many APs is judged per-AP.
"""
import json
import os
import re
import socket
import sqlite3
import subprocess
import sys
import time

CONF = os.environ.get("GEWGAW_CONF", "/etc/gewgaw/gewgaw.conf")
AWS_CONF = os.environ.get("AWS_IOT_CONF", "/etc/aws-iot/aws-iot.conf")

# Fallbacks for anything missing from the config file.
DEFAULTS = {
    "GEWGAW_DB": "/var/lib/gewgaw/gewgaw.db",
    "GEWGAW_SOCK": "/run/gewgaw/arbiter.sock",
    "WIFI_IFACE": "wlan0",
    "SESSION_GAP": "300",
    "KNOWN_NETWORKS": "/etc/gewgaw/networks.conf",
    "ALLOW_OPEN": "1",
    "MAX_ATTEMPTS": "4",
    "LEASE_SECONDS": "180",
    "CONNECT_TIMEOUT": "45",
    "HTTP_CHECK_URL": "http://connectivitycheck.gstatic.com/generate_204",
    "SUBMIT_BATCH": "200",
    # boot phase (§8.1)
    "WAIT_FOR_SCAN": "60",
    "BOOT_CONNECT_BUDGET": "300",
    "BOOT_LEASE_SECONDS": "450",
    "NTP_WAIT": "90",
}


def log(msg):
    print(f"gewgaw-submit: {msg}", flush=True)


def load_conf(path):
    """Parse the shell-style KEY=VALUE config into a dict, over DEFAULTS."""
    cfg = dict(DEFAULTS)
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, val = line.partition("=")
                val = val.split("#", 1)[0].strip().strip('"').strip("'")
                cfg[key.strip()] = val
    except FileNotFoundError:
        log(f"config {path} not found; using defaults")
    return cfg


def run(cmd, timeout=30, combine=False):
    """Run a command; return (returncode, output). Never raises."""
    try:
        p = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout)
        out = p.stdout + (p.stderr if combine else "")
        return p.returncode, out
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError) as e:
        log(f"command failed: {' '.join(cmd)}: {e}")
        return 1, ""


# --- config-derived bits --------------------------------------------------

def read_topic_base(aws_conf):
    """Derive gewgaw/<thing> from aws-iot.conf's AWS_IOT_TOPIC (…/<thing>/test)."""
    try:
        with open(aws_conf) as f:
            for line in f:
                line = line.strip()
                if line.startswith("AWS_IOT_TOPIC"):
                    val = line.partition("=")[2].strip().strip('"').strip("'")
                    return val.rsplit("/", 1)[0] if "/" in val else val
    except FileNotFoundError:
        pass
    return None


# --- database -------------------------------------------------------------

def connect_db(db_path):
    conn = sqlite3.connect(db_path, timeout=10)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode = WAL")
    conn.execute("PRAGMA busy_timeout = 5000")
    return conn


def count_pending(conn):
    return conn.execute(
        "SELECT COUNT(*) FROM sessions WHERE ended_at IS NOT NULL "
        "AND synced = 0").fetchone()[0]


def count_pending_events(conn):
    return conn.execute(
        "SELECT COUNT(*) FROM events WHERE synced = 0").fetchone()[0]


def visible_aps(conn, gap, now):
    """APs the collector currently sees: open wifi_ap sessions within SESSION_GAP."""
    rows = conn.execute(
        "SELECT d.address AS bssid, d.meta AS meta, s.rssi_last AS rssi "
        "FROM sessions s JOIN devices d ON d.id = s.device_id "
        "WHERE d.kind = 'wifi_ap' AND s.ended_at IS NULL "
        "AND ? - s.last_sight <= ?", (now, gap)).fetchall()
    out = []
    for r in rows:
        try:
            meta = json.loads(r["meta"]) if r["meta"] else {}
        except (ValueError, TypeError):
            meta = {}
        out.append({"bssid": r["bssid"], "ssid": meta.get("ssid"),
                    "enc": meta.get("enc"), "rssi": r["rssi"]})
    return out


# --- known-networks file (wpa_supplicant-native, §12) ---------------------

def parse_networks_conf(path):
    """Parse wpa_supplicant `network={}` blocks -> [{ssid, psk, key_mgmt, priority}]."""
    nets = []
    cur = None
    try:
        with open(path) as f:
            text = f.read()
    except FileNotFoundError:
        return nets
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("network=") and "{" in line:
            cur = {"ssid": None, "psk": None, "key_mgmt": None, "priority": 0}
            continue
        if cur is None:
            continue
        if line.startswith("}"):
            if cur.get("ssid"):
                nets.append(cur)
            cur = None
            continue
        if "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip()
        if key == "ssid":
            cur["ssid"] = val.strip('"')
        elif key == "psk":
            cur["psk"] = val.strip('"')   # quoted passphrase or 64-hex PSK
        elif key == "key_mgmt":
            cur["key_mgmt"] = val
        elif key == "priority":
            try:
                cur["priority"] = int(val)
            except ValueError:
                pass
    return nets


def select_candidates(visible, known, allow_open, blacklist=None):
    """Order APs to try: known PSK first (by priority/rssi), then open by rssi.

    `blacklist` is the set of BSSIDs currently in net_health cooldown (§9); they
    are dropped here so the short upload window isn't spent on known-dead APs.
    """
    blacklist = blacklist or set()
    by_ssid = {n["ssid"]: n for n in known if n.get("ssid")}
    known_psk, known_open, disc_open = [], [], []
    seen_ssids = set()

    def rssi_key(c):
        return c["rssi"] if c["rssi"] is not None else -999

    for ap in visible:
        if ap["bssid"] in blacklist:
            continue            # in cooldown (§9) — skip this AP
        ssid = ap.get("ssid")
        if not ssid:
            continue
        kn = by_ssid.get(ssid)
        if kn is not None:
            if ssid in seen_ssids:
                continue            # one attempt per known SSID (assoc by SSID)
            seen_ssids.add(ssid)
            is_open = (kn.get("key_mgmt") == "NONE") or not kn.get("psk")
            cand = {"ssid": ssid, "bssid": ap["bssid"], "psk": kn.get("psk"),
                    "is_open": is_open, "priority": kn.get("priority", 0),
                    "rssi": ap["rssi"]}
            (known_open if is_open else known_psk).append(cand)
        elif allow_open and ap.get("enc") == "open":
            disc_open.append({"ssid": ssid, "bssid": ap["bssid"], "psk": None,
                              "is_open": True, "priority": 0, "rssi": ap["rssi"]})

    known_psk.sort(key=lambda c: (c["priority"], rssi_key(c)), reverse=True)
    known_open.sort(key=lambda c: (c["priority"], rssi_key(c)), reverse=True)
    disc_open.sort(key=rssi_key, reverse=True)
    return known_psk + known_open + disc_open


# --- net_health blacklist (§9) --------------------------------------------
#
# Per-BSSID uplink reputation so the brief upload window isn't wasted re-trying
# dead/captive hotspots. On failure a BSSID gets an exponentially-backed-off
# cooldown; a success clears it. Open networks get the full ladder (captive
# portals start a rung higher — they're reliably useless to us); configured PSK
# networks get a gentle ladder, since a known network failing is usually
# transient. Re-probe is never permanent: the 7-day cap means a long-dead AP is
# eventually retried once, and a single fresh failure re-arms the long backoff.

OPEN_BACKOFF = [15 * 60, 60 * 60, 6 * 3600, 24 * 3600, 7 * 24 * 3600]
PSK_BACKOFF = [5 * 60, 15 * 60, 30 * 60, 60 * 60]


def backoff_seconds(fail_count, is_open, reason):
    """Cooldown (s) after `fail_count` consecutive failures of a BSSID (§9)."""
    if is_open:
        ladder = OPEN_BACKOFF[1:] if reason == "captive" else OPEN_BACKOFF
    else:
        ladder = PSK_BACKOFF
    idx = min(max(fail_count, 1), len(ladder)) - 1
    return ladder[idx]


def cooled_down_bssids(conn, now):
    """Set of BSSIDs still in cooldown — dropped from candidate selection."""
    rows = conn.execute(
        "SELECT bssid FROM net_health WHERE cooldown_until > ?",
        (now,)).fetchall()
    return {r["bssid"] for r in rows}


def net_in_cooldown(conn, bssid, now):
    return conn.execute(
        "SELECT 1 FROM net_health WHERE bssid = ? AND cooldown_until > ?",
        (bssid, now)).fetchone() is not None


def net_record_fail(conn, cand, reason, now):
    """Bump a BSSID's consecutive-failure count and (re)arm its cooldown."""
    row = conn.execute(
        "SELECT fail_count FROM net_health WHERE bssid = ?",
        (cand["bssid"],)).fetchone()
    fail_count = (row["fail_count"] if row else 0) + 1
    cooldown_until = now + backoff_seconds(fail_count, cand["is_open"], reason)
    if row is None:
        conn.execute(
            "INSERT INTO net_health (bssid, ssid, is_open, last_attempt, "
            "fail_count, last_fail_reason, cooldown_until) "
            "VALUES (?, ?, ?, ?, ?, ?, ?)",
            (cand["bssid"], cand["ssid"], 1 if cand["is_open"] else 0, now,
             fail_count, reason, cooldown_until))
    else:
        conn.execute(
            "UPDATE net_health SET ssid = ?, is_open = ?, last_attempt = ?, "
            "fail_count = ?, last_fail_reason = ?, cooldown_until = ? "
            "WHERE bssid = ?",
            (cand["ssid"], 1 if cand["is_open"] else 0, now, fail_count,
             reason, cooldown_until, cand["bssid"]))
    conn.commit()
    return cooldown_until


def net_record_success(conn, cand, now):
    """Clear a BSSID's failure streak and cooldown after a good uplink."""
    row = conn.execute(
        "SELECT bssid FROM net_health WHERE bssid = ?",
        (cand["bssid"],)).fetchone()
    if row is None:
        conn.execute(
            "INSERT INTO net_health (bssid, ssid, is_open, last_attempt, "
            "last_success, fail_count, cooldown_until) "
            "VALUES (?, ?, ?, ?, ?, 0, 0)",
            (cand["bssid"], cand["ssid"], 1 if cand["is_open"] else 0, now, now))
    else:
        conn.execute(
            "UPDATE net_health SET ssid = ?, is_open = ?, last_attempt = ?, "
            "last_success = ?, fail_count = 0, last_fail_reason = NULL, "
            "cooldown_until = 0 WHERE bssid = ?",
            (cand["ssid"], 1 if cand["is_open"] else 0, now, now, cand["bssid"]))
    conn.commit()


# --- wpa_supplicant association -------------------------------------------

def wpa_conf_path(iface):
    return f"/etc/wpa_supplicant/wpa_supplicant-{iface}.conf"


def write_transient_conf(iface, cand):
    """Single-network wpa_supplicant conf for one candidate (secret, 0600)."""
    if cand["is_open"]:
        netblock = '    key_mgmt=NONE\n'
    else:
        psk = cand["psk"] or ""
        if re.fullmatch(r"[0-9a-fA-F]{64}", psk):
            netblock = f'    psk={psk}\n'          # pre-hashed PSK, no quotes
        else:
            netblock = f'    psk="{psk}"\n'        # passphrase
    # Pin the exact BSSID so each attempt connects to — and is judged by
    # net_health (§9) as — the specific AP the collector saw. Open SSIDs like
    # "xfinitywifi" exist at many BSSIDs with independent health.
    bssid_line = f'    bssid={cand["bssid"]}\n' if cand.get("bssid") else ""
    body = ("ctrl_interface=/run/wpa_supplicant\n"
            "update_config=1\n"
            "network={\n"
            f'    ssid="{cand["ssid"]}"\n'
            f"{bssid_line}"
            f"{netblock}"
            "}\n")
    path = wpa_conf_path(iface)
    # The dir may not exist on a clean flash (only setup-wlan.sh would have made
    # it); create it before writing so opportunistic mode works without dev mode.
    os.makedirs(os.path.dirname(path), exist_ok=True)
    # Write 0600 from the start so the PSK is never briefly world-readable.
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    with os.fdopen(fd, "w") as f:
        f.write(body)


def wpa_state(iface):
    _, out = run(["wpa_cli", "-i", iface, "status"], timeout=10)
    m = re.search(r"^wpa_state=(\S+)", out, re.M)
    return m.group(1) if m else None


def have_ipv4(iface):
    _, out = run(["ip", "-4", "addr", "show", "dev", iface], timeout=10)
    return "inet " in out


def current_ipv4(iface):
    _, out = run(["ip", "-4", "-o", "addr", "show", "dev", iface], timeout=10)
    m = re.search(r"inet\s+(\d+\.\d+\.\d+\.\d+)", out)
    return m.group(1) if m else None


def associate(iface, cand, timeout):
    """Bring wlan0 onto one candidate. Returns (ok, reason)."""
    write_transient_conf(iface, cand)
    run(["systemctl", "restart", f"wpa_supplicant@{iface}"], timeout=30)
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if wpa_state(iface) == "COMPLETED":
            break
        time.sleep(1)
    else:
        return False, "assoc"
    # networkd runs DHCP via the shipped 80-gewgaw-wlan0.network; await an IP.
    while time.monotonic() < deadline:
        if have_ipv4(iface):
            return True, None
        time.sleep(1)
    return False, "dhcp"


def connectivity_reason(url, timeout):
    """204 => (True, None); else (False, 'captive'|'no_internet')."""
    _, out = run(["wget", "-S", "-O", "/dev/null", "-T", str(timeout), url],
                 timeout=timeout + 10, combine=True)
    m = re.search(r"HTTP/\S+\s+(\d{3})", out)
    if not m:
        return False, "no_internet"          # DNS/timeout/no route
    code = int(m.group(1))
    if code == 204:
        return True, None
    return False, "captive" if code in (200, 301, 302, 303, 307, 308) \
        else "no_internet"


def teardown(iface):
    """Idempotent: drop the link and remove the transient secret."""
    run(["systemctl", "stop", f"wpa_supplicant@{iface}"], timeout=30)
    run(["ip", "addr", "flush", "dev", iface], timeout=10)
    try:
        os.unlink(wpa_conf_path(iface))
    except FileNotFoundError:
        pass


def connect_any(iface, cands, connect_timeout, url, conn=None, deadline=None,
                max_attempts=None):
    """Try candidates until one yields real internet; return the winner or None.

    Two stop policies (shared by both modes):
      * steady-state (§8): a single pass capped at `max_attempts`.
      * boot (§8.1): keep cycling the list until monotonic `deadline`, pausing
        between sweeps so a momentarily-out-of-range AP can be retried.
    When `conn` is given, each attempt updates the per-BSSID net_health
    reputation (§9): a failure arms an exponential cooldown, a success clears it.
    A BSSID that falls into cooldown mid-run (e.g. across boot re-sweeps) is
    skipped; if a whole sweep finds nothing left to try, we stop early.
    """
    if not cands:
        return None
    attempt = 0
    while True:
        swept = 0
        for cand in cands:
            if deadline is not None and time.monotonic() >= deadline:
                return None
            if max_attempts is not None and attempt >= max_attempts:
                return None
            if conn is not None and net_in_cooldown(
                    conn, cand["bssid"], int(time.time())):
                continue            # cooled down mid-run (§9)
            swept += 1
            attempt += 1
            tag = (f"{cand['ssid']} ({cand['bssid']}, "
                   f"{'open' if cand['is_open'] else 'psk'})")
            log(f"trying {tag} [attempt {attempt}]")
            ok, reason = associate(iface, cand, connect_timeout)
            if not ok:
                log(f"  association failed: {reason}")
                if conn is not None:
                    net_record_fail(conn, cand, reason, int(time.time()))
                teardown(iface)
                continue
            cok, creason = connectivity_reason(url, 15)
            if not cok:
                log(f"  no internet: {creason}")
                if conn is not None:
                    net_record_fail(conn, cand, creason, int(time.time()))
                teardown(iface)
                continue
            log(f"  online via {tag}")
            if conn is not None:
                net_record_success(conn, cand, int(time.time()))
            return cand
        if deadline is None:
            return None             # steady-state: one pass only
        if swept == 0:
            return None             # everything left is in cooldown
        if time.monotonic() >= deadline:
            return None
        time.sleep(5)              # boot budget remains; re-sweep the list


# --- radio lease (arbiter client, §6) -------------------------------------

class RadioLease:
    """Acquire the collector's radio lease for the duration of a `with` block.

    If the arbiter socket is absent (collector not running) we proceed without a
    lease — there is then no scanner to contend with. A connected-but-refused
    grant raises, so we never retune the radio behind an active scan.
    """

    def __init__(self, sock_path, seconds):
        self.sock_path = sock_path
        self.seconds = seconds
        self.sock = None

    def __enter__(self):
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(self.seconds + 30)
            s.connect(self.sock_path)
        except OSError as e:
            log(f"arbiter unavailable ({e}); proceeding without a radio lease")
            return self
        f = s.makefile("rwb", buffering=0)
        f.write(f"ACQUIRE {self.seconds}\n".encode())
        reply = f.readline().decode().strip()
        if reply != "GRANTED":
            s.close()
            raise RuntimeError(f"arbiter refused lease: {reply!r}")
        self.sock = s
        self._f = f
        log(f"radio lease granted ({self.seconds}s)")
        return self

    def __exit__(self, *exc):
        if self.sock is not None:
            try:
                self._f.write(b"RELEASE\n")
                self._f.readline()
            except OSError:
                pass
            try:
                self.sock.close()
            except OSError:
                pass
            log("radio lease released")
        return False


# --- upload (§10) ---------------------------------------------------------

def session_payload(row):
    try:
        meta = json.loads(row["meta"]) if row["meta"] else {}
    except (ValueError, TypeError):
        meta = {}
    obj = {
        "kind": row["kind"],
        "address": row["address"],
        "started_at": row["started_at"],
        "ended_at": row["ended_at"],
        "sighting_count": row["sighting_count"],
        "rssi_min": row["rssi_min"],
        "rssi_max": row["rssi_max"],
        "rssi_last": row["rssi_last"],
    }
    if row["kind"] == "wifi_ap":
        obj["ssid"] = meta.get("ssid")
        obj["channel"] = meta.get("channel")
        obj["enc"] = meta.get("enc")
    else:
        obj["name"] = meta.get("ble_name")
    return obj


def flush_sightings(conn, base_topic, batch):
    """Upload closed, unsynced sessions in chunks; mark synced after each pub."""
    rows = conn.execute(
        "SELECT s.id AS id, d.kind AS kind, d.address AS address, "
        "d.meta AS meta, s.started_at, s.ended_at, s.sighting_count, "
        "s.rssi_min, s.rssi_max, s.rssi_last "
        "FROM sessions s JOIN devices d ON d.id = s.device_id "
        "WHERE s.ended_at IS NOT NULL AND s.synced = 0 "
        "ORDER BY s.id").fetchall()
    topic = f"{base_topic}/sightings"
    uploaded = 0
    for i in range(0, len(rows), batch):
        chunk = rows[i:i + batch]
        payload = json.dumps([session_payload(r) for r in chunk])
        rc, _ = run(["aws-iot-mqtt", "pub", topic, payload], timeout=60)
        if rc != 0:
            log(f"pub to {topic} failed (rc={rc}); leaving "
                f"{len(rows) - uploaded} session(s) for next run")
            break
        ids = [r["id"] for r in chunk]
        conn.execute(
            f"UPDATE sessions SET synced = 1 WHERE id IN "
            f"({','.join('?' * len(ids))})", ids)
        conn.commit()
        uploaded += len(chunk)
        log(f"uploaded {len(chunk)} session(s) to {topic}")
    return uploaded


# --- events / boot beacon (§5.4, §8.1) ------------------------------------

def event_payload(row):
    """Reconstruct an event's JSON for upload (stored payload + type/ts/flag)."""
    try:
        detail = json.loads(row["payload"]) if row["payload"] else {}
    except (ValueError, TypeError):
        detail = {}
    detail.setdefault("ts", row["ts"])
    detail.setdefault("clock_synced", row["clock_synced"])
    detail["type"] = row["type"]
    return detail


def flush_events(conn, base_topic, batch):
    """Upload unsynced events to <base>/status; mark synced after each pub."""
    rows = conn.execute(
        "SELECT id, ts, type, clock_synced, payload FROM events "
        "WHERE synced = 0 ORDER BY id").fetchall()
    if not rows:
        return 0
    topic = f"{base_topic}/status"
    uploaded = 0
    for i in range(0, len(rows), batch):
        chunk = rows[i:i + batch]
        payload = json.dumps([event_payload(r) for r in chunk])
        rc, _ = run(["aws-iot-mqtt", "pub", topic, payload], timeout=60)
        if rc != 0:
            log(f"pub to {topic} failed (rc={rc}); leaving "
                f"{len(rows) - uploaded} event(s) for next run")
            break
        ids = [r["id"] for r in chunk]
        conn.execute(
            f"UPDATE events SET synced = 1 WHERE id IN "
            f"({','.join('?' * len(ids))})", ids)
        conn.commit()
        uploaded += len(chunk)
        log(f"uploaded {len(chunk)} event(s) to {topic}")
    return uploaded


def ntp_synced():
    """True if systemd reports the clock is NTP-synchronized."""
    _, out = run(["timedatectl", "show", "-p", "NTPSynchronized", "--value"],
                 timeout=10)
    val = out.strip().lower()
    if val in ("yes", "no"):
        return val == "yes"
    return "ntpsynchronized=yes" in out.strip().lower()  # older timedatectl


def wait_ntp(timeout):
    """Poll for NTPSynchronized=yes up to `timeout` seconds (>=1 probe)."""
    deadline = time.monotonic() + timeout
    while True:
        if ntp_synced():
            return True
        if time.monotonic() >= deadline:
            return False
        time.sleep(2)


def _read_os_release():
    data = {}
    try:
        with open("/etc/os-release") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                data[k.strip()] = v.strip().strip('"').strip("'")
    except OSError:
        pass
    return data


def _image_version():
    d = _read_os_release()
    return d.get("BUILD_ID") or d.get("VERSION_ID") or d.get("VERSION")


def _uptime_seconds():
    try:
        with open("/proc/uptime") as f:
            return int(float(f.read().split()[0]))
    except (OSError, ValueError, IndexError):
        return None


def _rootfs_free():
    try:
        st = os.statvfs("/")
        return st.f_bavail * st.f_frsize
    except OSError:
        return None


def boot_payload(conn, synced, ip=None, ssid=None):
    """Boot beacon payload (§8.1 / decision Q7)."""
    return {
        "ts": int(time.time()),
        "clock_synced": 1 if synced else 0,
        "uptime": _uptime_seconds(),
        "ip": ip,
        "ssid": ssid,
        "image_version": _image_version(),
        "kernel": os.uname().release,
        "pending_sightings": count_pending(conn),
        "disk_free": _rootfs_free(),
    }


def record_event(conn, etype, payload, synced):
    cur = conn.execute(
        "INSERT INTO events (ts, type, clock_synced, payload, synced) "
        "VALUES (?, ?, ?, ?, 0)",
        (payload["ts"], etype, 1 if synced else 0, json.dumps(payload)))
    conn.commit()
    return cur.lastrowid


def update_event(conn, event_id, payload, synced):
    conn.execute(
        "UPDATE events SET ts = ?, clock_synced = ?, payload = ? WHERE id = ?",
        (payload["ts"], 1 if synced else 0, json.dumps(payload), event_id))
    conn.commit()


# --- modes ----------------------------------------------------------------

def upload_run(cfg):
    iface = cfg["WIFI_IFACE"]
    conn = connect_db(cfg["GEWGAW_DB"])
    try:
        pending_s = count_pending(conn)
        pending_e = count_pending_events(conn)
        if pending_s == 0 and pending_e == 0:
            log("nothing to upload (no closed unsynced sessions or events)")
            return 0
        log(f"{pending_s} session(s) + {pending_e} event(s) pending upload")

        base = read_topic_base(AWS_CONF)
        if not base:
            log(f"could not derive topic base from {AWS_CONF}; aborting")
            return 1

        now = int(time.time())
        gap = int(cfg["SESSION_GAP"])
        cands = select_candidates(
            visible_aps(conn, gap, now),
            parse_networks_conf(cfg["KNOWN_NETWORKS"]),
            cfg["ALLOW_OPEN"] == "1",
            cooled_down_bssids(conn, now))
        if not cands:
            log("no usable AP visible right now; will retry next run")
            return 0
        log(f"{len(cands)} candidate AP(s); trying up to {cfg['MAX_ATTEMPTS']}")

        batch = int(cfg["SUBMIT_BATCH"])
        with RadioLease(cfg["GEWGAW_SOCK"], int(cfg["LEASE_SECONDS"])):
            try:
                winner = connect_any(
                    iface, cands, int(cfg["CONNECT_TIMEOUT"]),
                    cfg["HTTP_CHECK_URL"], conn=conn,
                    max_attempts=int(cfg["MAX_ATTEMPTS"]))
                if winner is not None:
                    # §10: flush events (boot beacons) first, then sightings.
                    flush_events(conn, base, batch)
                    flush_sightings(conn, base, batch)
            finally:
                teardown(iface)
        return 0
    finally:
        conn.close()


def boot_run(cfg):
    """Boot phase / first-connect beacon (§8.1)."""
    iface = cfg["WIFI_IFACE"]
    conn = connect_db(cfg["GEWGAW_DB"])
    try:
        base = read_topic_base(AWS_CONF)

        # 1. Record the boot intent FIRST so it survives a failed uplink (§5.4).
        synced = ntp_synced()
        payload = boot_payload(conn, synced)
        event_id = record_event(conn, "boot", payload, synced)
        log(f"recorded boot event #{event_id} "
            f"(clock_synced={int(synced)}, "
            f"pending_sightings={payload['pending_sightings']})")

        if not base:
            log(f"could not derive topic base from {AWS_CONF}; "
                "boot event queued for a later run")
            return 0

        # 2. The collector just started; wait for its first scan to surface a
        #    usable candidate (poll the DB up to WAIT_FOR_SCAN).
        gap = int(cfg["SESSION_GAP"])
        allow_open = cfg["ALLOW_OPEN"] == "1"
        known = parse_networks_conf(cfg["KNOWN_NETWORKS"])
        wait_deadline = time.monotonic() + int(cfg["WAIT_FOR_SCAN"])
        cands = []
        while True:
            now_s = int(time.time())
            cands = select_candidates(
                visible_aps(conn, gap, now_s), known, allow_open,
                cooled_down_bssids(conn, now_s))
            if cands or time.monotonic() >= wait_deadline:
                break
            time.sleep(3)
        if not cands:
            log(f"no candidate AP within {cfg['WAIT_FOR_SCAN']}s; "
                "boot event stays queued for the next run")
            return 0
        log(f"{len(cands)} candidate AP(s) at boot")

        # 3+4. Larger lease + a time budget more forgiving than a steady run.
        batch = int(cfg["SUBMIT_BATCH"])
        with RadioLease(cfg["GEWGAW_SOCK"], int(cfg["BOOT_LEASE_SECONDS"])):
            try:
                budget = int(cfg["BOOT_CONNECT_BUDGET"])
                winner = connect_any(
                    iface, cands, int(cfg["CONNECT_TIMEOUT"]),
                    cfg["HTTP_CHECK_URL"], conn=conn,
                    deadline=time.monotonic() + budget)
                if winner is None:
                    log(f"could not get online within {budget}s; "
                        "boot event stays queued for the next run")
                    return 0

                # 5. Confirm NTP, then re-stamp the boot event with the
                #    corrected clock and the actual link details.
                synced = wait_ntp(int(cfg["NTP_WAIT"]))
                ip = current_ipv4(iface)
                payload = boot_payload(conn, synced, ip=ip, ssid=winner["ssid"])
                update_event(conn, event_id, payload, synced)
                log(f"boot event re-stamped (clock_synced={int(synced)}, "
                    f"ip={ip}, ssid={winner['ssid']})")

                # 6. Flush events (the boot beacon) first, then sightings (§10).
                flush_events(conn, base, batch)
                flush_sightings(conn, base, batch)
            finally:
                teardown(iface)
        return 0
    finally:
        conn.close()


def main():
    cfg = load_conf(CONF)
    mode = sys.argv[1] if len(sys.argv) > 1 else "upload"
    if mode == "upload":
        return upload_run(cfg)
    if mode == "boot":
        return boot_run(cfg)
    log(f"unknown mode '{mode}' (use upload|boot)")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
